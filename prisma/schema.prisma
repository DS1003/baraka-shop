generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  role      Role      @default(USER)
  image     String?
  address   String?
  phone     String?   @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  username  String?   @unique
  metadata  Json?     @default("{}")
  orders    Order[]
  reviews   Review[]
  wishlist  Product[] @relation("Wishlist")
}

model Product {
  id                   String                @id @default(uuid())
  name                 String
  slug                 String                @unique
  description          String?
  price                Float
  oldPrice             Float?
  stock                Int                   @default(0)
  images               String[]
  videos               String[]
  categoryId           String
  subCategoryId        String?
  brandId              String?
  isFeatured           Boolean               @default(false)
  isNew                Boolean               @default(false)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  metadata             Json?                 @default("{}")
  thirdLevelCategoryId String?
  promotionId          String?
  storeId              String?
  features             Json?                 @default("[]")
  shortDescription     String?
  reference            String?               @unique
  detailedDescription  Json?                 @default("[]")
  isPublished          Boolean               @default(true)
  orderItems           OrderItem[]
  brand                Brand?                @relation(fields: [brandId], references: [id])
  category             Category              @relation(fields: [categoryId], references: [id])
  promotion            Promotion?            @relation(fields: [promotionId], references: [id])
  store                Store?                @relation(fields: [storeId], references: [id])
  subCategory          SubCategory?          @relation(fields: [subCategoryId], references: [id])
  thirdLevelCategory   ThirdLevelCategory?   @relation(fields: [thirdLevelCategoryId], references: [id])
  colorVariants        ProductColorVariant[]
  reviews              Review[]
  favoritedBy          User[]                @relation("Wishlist")

  @@index([name])
  @@index([slug])
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([thirdLevelCategoryId])
  @@index([brandId])
  @@index([storeId])
  @@index([stock])
}

model ProductColorVariant {
  id        String   @id @default(uuid())
  colorName String
  colorHex  String
  images    String[]
  productId String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Category {
  id            String        @id @default(uuid())
  name          String        @unique
  slug          String        @unique
  image         String?
  isPublished   Boolean       @default(true)
  products      Product[]
  subCategories SubCategory[]
}

model SubCategory {
  id                   String               @id @default(uuid())
  name                 String
  slug                 String               @unique
  categoryId           String
  products             Product[]
  category             Category             @relation(fields: [categoryId], references: [id])
  thirdLevelCategories ThirdLevelCategory[]

  @@unique([name, categoryId])
}

model ThirdLevelCategory {
  id            String      @id @default(uuid())
  name          String
  slug          String      @unique
  subCategoryId String
  products      Product[]
  subCategory   SubCategory @relation(fields: [subCategoryId], references: [id])

  @@unique([name, subCategoryId])
}

model Brand {
  id       String    @id @default(uuid())
  name     String    @unique
  slug     String    @unique
  image    String?
  products Product[]
}

model Order {
  id             String      @id @default(uuid())
  userId         String
  status         OrderStatus @default(PENDING)
  total          Float
  paymentMethod  String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deliveryMethod String?
  deliveryZone   String?
  shippingCost   Float?      @default(0)
  user           User        @relation(fields: [userId], references: [id])
  items          OrderItem[]
}

model OrderItem {
  id            String  @id @default(uuid())
  orderId       String
  productId     String
  quantity      Int
  price         Float
  selectedColor String?
  order         Order   @relation(fields: [orderId], references: [id])
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model ImportJob {
  id             String   @id @default(uuid())
  status         String   @default("PENDING")
  progress       Int      @default(0)
  totalItems     Int      @default(0)
  processedItems Int      @default(0)
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Media {
  id        String   @id @default(uuid())
  name      String
  url       String
  publicId  String   @unique
  format    String?
  size      Int?
  type      String   @default("image")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model MediaJob {
  id             String   @id @default(uuid())
  status         String   @default("PENDING")
  progress       Int      @default(0)
  totalItems     Int      @default(0)
  processedItems Int      @default(0)
  matchedCount   Int      @default(0)
  error          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Promotion {
  id                 String    @id @default(uuid())
  name               String
  description        String?
  startDate          DateTime
  endDate            DateTime
  discountPercentage Float
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  products           Product[]
}

model Store {
  id             String    @id @default(uuid())
  name           String    @unique
  slug           String    @unique
  logo           String?
  description    String?
  address        String?
  phone          String?
  hours          String?
  type           String?
  city           String?
  mapUrl         String?
  isClickCollect Boolean   @default(false)
  isSav          Boolean   @default(false)
  isBarakaShop   Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  banner         String?
  logo_detail    String?
  products       Product[]
}

model PopularUniverse {
  id        String   @id @default(uuid())
  name      String
  subtitle  String?
  image     String?
  href      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomePromo {
  id        String   @id @default(uuid())
  badge     String?
  title     String
  subtitle  String?
  price     String?
  image     String
  bg        String   @default("bg-slate-50")
  border    String   @default("border-slate-100")
  size      String   @default("md:col-span-1")
  href      String   @default("/boutique")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BigBanner {
  id          String   @id @default(uuid())
  title       String
  subtitle    String?
  description String?
  badge       String?
  image       String
  href        String   @default("/boutique")
  buttonText  String   @default("Commander")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SiteConfig {
  id                 String   @id @default("singleton")
  maintenanceMode    Boolean  @default(false)
  maintenanceTitle   String   @default("Site en maintenance")
  maintenanceMessage String   @default("Nous effectuons des améliorations. Le site sera de retour très bientôt.")
  updatedAt          DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model PhysicalStore {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  image          String?
  description    String?
  address        String?
  phone          String?
  hours          String?
  type           String?
  city           String?
  mapUrl         String?
  isClickCollect Boolean  @default(false)
  isSav          Boolean  @default(false)
  isPublished    Boolean  @default(true)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
