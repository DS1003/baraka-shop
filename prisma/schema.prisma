generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model User {
  id            String    @id @default(uuid())
  username      String?   @unique
  email         String    @unique
  password      String
  role          Role      @default(USER)
  image         String?
  address       String?
  phone         String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders        Order[]
  reviews       Review[]
  wishlist      Product[] @relation("Wishlist")
}

model Product {
  id            String       @id @default(uuid())
  name          String
  slug          String       @unique
  reference     String?      @unique
  description   String
  shortDescription String?
  features      Json?        @default("[]")
  price         Float
  oldPrice      Float?
  stock         Int          @default(0)
  images        String[]
  category      Category     @relation(fields: [categoryId], references: [id])
  categoryId    String
  subCategory   SubCategory? @relation(fields: [subCategoryId], references: [id])
  subCategoryId String?
  thirdLevelCategory   ThirdLevelCategory? @relation(fields: [thirdLevelCategoryId], references: [id])
  thirdLevelCategoryId String?
  brand         Brand?       @relation(fields: [brandId], references: [id])
  brandId       String?
  isFeatured    Boolean      @default(false)
  isNew         Boolean      @default(false)
  metadata      Json?        @default("{}")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  store         Store?       @relation(fields: [storeId], references: [id])
  storeId       String?

  promotion     Promotion?   @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  promotionId   String?

  reviews     Review[]
  orderItems  OrderItem[]
  favoritedBy User[]    @relation("Wishlist")
  colorVariants ProductColorVariant[]

  @@index([name])
  @@index([slug])
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([thirdLevelCategoryId])
  @@index([brandId])
  @@index([storeId])
  @@index([stock])
}

model ProductColorVariant {
  id        String   @id @default(uuid())
  colorName String
  colorHex  String
  images    String[]
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model Category {
  id            String        @id @default(uuid())
  name          String        @unique
  slug          String        @unique
  image         String?
  subCategories SubCategory[]
  products      Product[]
}

model SubCategory {
  id         String    @id @default(uuid())
  name       String
  slug       String    @unique
  category   Category  @relation(fields: [categoryId], references: [id])
  categoryId String
  thirdLevelCategories ThirdLevelCategory[]
  products   Product[]

  @@unique([name, categoryId])
}

model ThirdLevelCategory {
  id            String      @id @default(uuid())
  name          String
  slug          String      @unique
  subCategory   SubCategory @relation(fields: [subCategoryId], references: [id])
  subCategoryId String
  products      Product[]

  @@unique([name, subCategoryId])
}

model Brand {
  id       String    @id @default(uuid())
  name     String    @unique
  slug     String    @unique
  image    String?
  products Product[]
}

model Order {
  id             String      @id @default(uuid())
  user           User        @relation(fields: [userId], references: [id])
  userId         String
  status         OrderStatus @default(PENDING)
  total          Float
  paymentMethod  String?
  deliveryMethod String?     // "livraison" or "retrait"
  deliveryZone   String?     // Zone name chosen by customer
  shippingCost   Float?      @default(0)
  items          OrderItem[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model OrderItem {
  id        String  @id @default(uuid())
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  quantity  Int
  price     Float
  selectedColor String?
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  createdAt DateTime @default(now())
}

model ImportJob {
  id            String   @id @default(uuid())
  status        String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED, PAUSED, CANCELLED
  progress      Int      @default(0)
  totalItems    Int      @default(0)
  processedItems Int      @default(0)
  error         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Media {
  id        String   @id @default(uuid())
  name      String
  url       String
  publicId  String   @unique
  format    String?
  size      Int?
  type      String   @default("image") // image, video, raw
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model MediaJob {
  id             String   @id @default(uuid())
  status         String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, FAILED
  progress       Int      @default(0)
  totalItems     Int      @default(0)
  processedItems Int      @default(0)
  matchedCount   Int      @default(0)
  error          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Promotion {
  id                 String    @id @default(uuid())
  name               String
  description        String?
  startDate          DateTime
  endDate            DateTime
  discountPercentage Float
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  products           Product[]
}

model Store {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  logo        String?
  logo_detail String?
  banner      String?
  description String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PopularUniverse {
  id        String   @id @default(uuid())
  name      String
  subtitle  String?
  image     String?
  href      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomePromo {
  id        String   @id @default(uuid())
  badge     String?
  title     String
  subtitle  String?
  price     String?
  image     String
  bg        String   @default("bg-slate-50")
  border    String   @default("border-slate-100")
  size      String   @default("md:col-span-1")
  href      String   @default("/boutique")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BigBanner {
  id          String   @id @default(uuid())
  title       String
  subtitle    String?
  description String?
  badge       String?
  image       String
  href        String   @default("/boutique")
  buttonText  String   @default("Commander")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}